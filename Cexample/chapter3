함수 사용해서 수정

#include <stdio.h>

void convert_volume(float cups) 
{
    float pints, ounces, tablespoons, teaspoons;
    
    pints = cups / 2;
    ounces = 8 * cups;
    tablespoons = 16 * cups;
    teaspoons = 32 * cups;
    
    
    printf("\n입력한 부피(cup 단위):%.1fcups", cups);
    printf("\n%.1f cups = %.1f pints\n", cups, pints);
    printf("%.1f cups = %.1f ounces\n", cups, ounces);
    printf("%.1f cups = %.1f tablespoons\n", cups, tablespoons);
    printf("%.1f cups = %.1f teaspoons\n", cups, teaspoons);
}

int main()
{
    float cups;
    
    printf("cup단위로 부피 입력(소수점 이하 한자릿 수까지 입력):");
    scanf("%f", &cups);
    
    convert_volume(cups);
    
    return 0;
}
