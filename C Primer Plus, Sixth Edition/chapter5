#include <stdio.h>
#define H_PER_M 60

int main()
{
    int time, min, hour;
    
    printf("분 수 입력(0 입력시 종료):");
    scanf("%d", &time);
    
    while (time > 0)
    {
        hour = time / H_PER_M;
        min = time % H_PER_M;
        printf("%d분은 %d시간 %d분\n", time, hour, min);
        printf("분 수 입력:");
        scanf("%d", &time);
    }
    
    printf("종료!");

    return 0;
}

