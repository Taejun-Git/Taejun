#include <stdio.h>

int main()
{
    int work_day, sum, count;
    
    sum = 0;
    count = 1;
    
    printf("일한 날의 수 입력(최대 20일):");
    scanf("%d", &work_day);
    
    while (count <= work_day)
        sum = sum + count++;
    
    printf("%d일할 시 받는 급료:%d", work_day, sum);
    
    return 0;
}

