#include <stdio.h>
const double ratio = 5.0/9.0;
const double freezing_point = 32.0;
const double control_point_diff = 273.16;

void Temperatures(double Fahrenheit);

int main()
{
    double Fahrenheit;
    
    printf("화씨온도 입력:");
    
    while (scanf("%lf", &Fahrenheit) == 1)
    {
        Temperatures(Fahrenheit);
        printf("화씨온도 입력:");
    }
    
    printf("문자 입력시 프로그램 종료");
    
}

void Temperatures(double Fahrenheit)
{
    printf("섭씨온도: %.2f\n", ratio * (Fahrenheit - freezing_point));
    printf("절대온도: %.2f\n", Fahrenheit + control_point_diff);
}
