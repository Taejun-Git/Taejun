#include <stdio.h>

float cube(float f);

int main()
{
    float f;
    printf("부동소수점 수 입력:");
    scanf("%f", &f);
    printf("%.1f의 세 제곱은 %.1f입니다.", f, cube(f));

    return 0;
}

float cube(float f)
{
    return f * f * f;
}

