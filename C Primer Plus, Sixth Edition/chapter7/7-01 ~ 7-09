7-1 // switch 이용

#include <stdio.h>

int main(void)
{
    char ch;
    int character = 0, space = 0, new_line = 0;
    
    printf("문자열 입력: ");
    
    while ((ch = getchar()) != '#')
    {
        switch (ch)
        {
            case ' ' : space++;
                       break;
            
            case '\n' : new_line++;
                        break;
                        
            default : character++;
                      break;
        }
    }
    
    printf("읽은 스페이스의 수: %d, 읽은 개행 문자의 수; %d 모든 문자의 수; %d\n", space, new_line, character);
        
    return 0;
}

