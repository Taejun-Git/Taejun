int main()
{
    unsigned int num;
    int count = 0;
    
    printf("2이상의 정수를 입력하시오: ");
    
    while ((count = scanf("%u", &num)) == 1)
    {
        int i, j;
        for (i = 2; i <= num; i++)
        {
            for (j = 1; j <= i; j++)
            {
                if (i % j == 0)
                    count++;
            }
            
            if (count == 2)
                printf("%d ", i);
        }
    }
    return 0;
}
