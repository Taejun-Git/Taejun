#include <stdio.h>

int main(void)
{
    int upper, lower;

    printf("정수로 하한과 상한을 입력하시오: ");
    scanf("%d %d", &lower, &upper);
        
    while (lower < upper)
    {
        int sum = 0;
        
        for (int copy_lower = lower; copy_lower <= upper; copy_lower++)
        {
            sum += copy_lower * copy_lower;
        }
        
        printf("%d부터 %d까지, 제곱들의 합은 %d\n", lower, upper, sum);
        printf("다음 하한과 상한을 입력하시오: ");
        scanf("%d %d", &lower, &upper);
    }

    printf("종료!\n");
    return 0;
}

